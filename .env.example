# ── sales-dashboard-v2 — independent instance ──────────────────────
# Fill these in with the NEW Google Apps Script deployments / Sheet IDs
# for this instance. Until then, backend-dependent features will not work.

# Apps Script web-app /exec URLs (one deployment per tool)
PO_GOOGLE_APPS_SCRIPT_URL=
PR_GOOGLE_APPS_SCRIPT_URL=
MRO_GOOGLE_APPS_SCRIPT_URL=
QUOTATION_GOOGLE_APPS_SCRIPT_URL=
MI_GOOGLE_APPS_SCRIPT_URL=
DASHBOARD_APPS_SCRIPT_URL=
PAYMENT_REQUEST_APPS_SCRIPT_URL=

# Google Sheet IDs
INVENTORY_SHEET_ID=
MRO_SHEET_ID=
MI_SHEET_ID=

# Secrets (generate fresh for this instance)
EMAIL_CRED_KEY=
INTERNAL_SHARED_SECRET=

# Email (IMAP)
GODADDY_IMAP_HOST=imap.secureserver.net

# Accounting Process Flow backend (FlowAPI.gs) — also set in dashboard/js/flow-api.js
FLOW_APPS_SCRIPT_URL=
